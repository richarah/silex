       21:   24:COLD void err_sys(const char *name, const char *fmt, ...)
        -:   25:{
       21:   26:    int saved = errno;
       21:   27:    va_list ap;
       21:   28:    fprintf(stderr, "matchbox");
       21:   29:    if (name && *name)
       21:   30:        fprintf(stderr, ": %s", name);
