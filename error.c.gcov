        8:   11:COLD void err_msg(const char *name, const char *fmt, ...)
        -:   12:{
        8:   13:    va_list ap;
        8:   14:    fprintf(stderr, "matchbox");
        8:   15:    if (name && *name)
        8:   16:        fprintf(stderr, ": %s", name);
        8:   17:    fprintf(stderr, ": ");
        8:   18:    va_start(ap, fmt);
        8:   19:    vfprintf(stderr, fmt, ap);
        8:   20:    va_end(ap);
        8:   21:    fputc('\n', stderr);
