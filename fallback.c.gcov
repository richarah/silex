        -:    5:/*
        -:    6: * fallback.c — sequential execution of batch operations.
        -:    7: *
        -:    8: * This is the always-correct fallback path used when io_uring is
        -:    9: * unavailable, the operations are not independent, or the uring path
        -:   10: * fails at setup time.
        -:   11: *
        -:   12: * Supported operations:
        -:   13: *   BATCH_MKDIR   — mkdir(path, mode)
        -:   14: *   BATCH_CHMOD   — chmod(path, mode)
        -:   15: *   BATCH_TOUCH   — utimensat(AT_FDCWD, path, NULL, 0)  [set to current time]
        -:   16: *   BATCH_RM_FILE — unlink(path)
        -:   17: */
        -:   18:
        -:   19:#include "fallback.h"
        -:   20:
        -:   21:#include <errno.h>
        -:   22:#include <fcntl.h>
        -:   23:#include <stdio.h>
        -:   24:#include <string.h>
        -:   25:#include <sys/stat.h>
        -:   26:#include <sys/types.h>
        -:   27:#include <unistd.h>
        -:   28:
        -:   29:/* utimensat is declared in <sys/stat.h> with _POSIX_C_SOURCE 200809L */
        -:   30:#include <fcntl.h>   /* AT_FDCWD */
        -:   31:
