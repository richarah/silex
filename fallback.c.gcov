    #####:   38:            fprintf(stderr, "matchbox: batch op with NULL path; skipping\n");
    #####:   39:            ret = 1;
    #####:   40:            continue;
        -:   41:        }
        -:   42:
    #####:   43:        switch (op->type) {
        -:   44:
    #####:   45:        case BATCH_MKDIR:
    #####:   46:            if (mkdir(op->path, (mode_t)op->mode) != 0) {
    #####:   47:                fprintf(stderr, "matchbox: batch mkdir '%s': %s\n",
    #####:   48:                        op->path, strerror(errno));
    #####:   49:                ret = 1;
        -:   50:            }
    #####:   51:            break;
        -:   52:
    #####:   53:        case BATCH_CHMOD:
    #####:   54:            if (chmod(op->path, (mode_t)op->mode) != 0) {
    #####:   55:                fprintf(stderr, "matchbox: batch chmod '%s': %s\n",
    #####:   56:                        op->path, strerror(errno));
    #####:   57:                ret = 1;
        -:   58:            }
    #####:   59:            break;
        -:   60:
    #####:   61:        case BATCH_TOUCH:
        -:   62:            /*
        -:   63:             * Pass NULL for the times array: POSIX specifies that this sets
        -:   64:             * both atime and mtime to the current time.
        -:   65:             */
    #####:   66:            if (utimensat(AT_FDCWD, op->path, NULL, 0) != 0) {
