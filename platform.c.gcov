        -:   47:#  elif defined(__aarch64__)
        -:   48:#    define SYS_io_uring_setup 425
        -:   49:#  elif defined(__arm__)
        -:   50:#    define SYS_io_uring_setup 425
        -:   51:#  elif defined(__riscv)
        -:   52:#    define SYS_io_uring_setup 425
        -:   53:#  else
        -:   54:/* Unknown arch: disable io_uring */
        -:   55:#    define SYS_io_uring_setup (-1L)
        -:   56:#  endif
        -:   57:#endif
