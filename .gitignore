# Build outputs
build/

# PGO instrumentation data
*.gcda
*.gcno
*.profdata
*.profraw
pgo/

# Compiled module objects
*.so
*.a

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Test scratch files
/tmp/
tests/tmp/

# Stripped binaries produced manually
matchbox-stripped
*-stripped

# Core dumps (anchored to repo root to avoid shadowing src/core/)
/core
core.*
vgcore.*

# Coverage output (generated by make coverage / gcov)
*.gcov
*.gcda
*.gcno
coverage/

# External test suites (fetched on demand, not committed)
tests/external/repos/
tests/external/results/

# Backstop: scratch files that test suites write into $PWD.
# The harness runs suites in a temp dir (see tests/external/run-smoosh.sh), so
# these should never appear. If they do, a runner has regressed to running
# tests in-place.
/a[0-9]
/cmd.sh
/link.sh
/link_dir
/link_file
/showpid.sh
/scr[0-9]
/job_info
