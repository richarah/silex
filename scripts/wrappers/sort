#!/bin/sh
# Silex wrapper: sort with --parallel=nproc via uutils coreutils
# uutils-coreutils is extracted at image build time; busybox remains
# at /usr/bin/sort for system use. Falls back silently if uutils-coreutils is absent.
[ "$SILEX_WRAPPERS" = "off" ] && exec /usr/bin/sort "$@"
_impl=/usr/local/silex/bin/uutils-coreutils
if [ -x "$_impl" ]; then
    exec "$_impl" sort --parallel="$(nproc)" "$@"
else
    exec /usr/bin/sort "$@"
fi
