#!/bin/sh
# Shim: provide Debian dpkg-architecture output for build scripts
# Translates uname -m to Debian architecture names
MACHINE=$(uname -m)
case "$MACHINE" in
    x86_64)  DEB_ARCH="amd64" ;;
    aarch64) DEB_ARCH="arm64" ;;
    armv7l)  DEB_ARCH="armhf" ;;
    *)       DEB_ARCH="$MACHINE" ;;
esac

for arg in "$@"; do
    case "$arg" in
        -qDEB_HOST_ARCH|-qDEB_BUILD_ARCH)
            echo "$DEB_ARCH"; exit 0 ;;
        -qDEB_HOST_MULTIARCH)
            case "$MACHINE" in
                x86_64)  echo "x86_64-linux-gnu" ;;
                aarch64) echo "aarch64-linux-gnu" ;;
                *)       echo "${MACHINE}-linux-gnu" ;;
            esac
            exit 0 ;;
    esac
done
# Default: print full table
echo "DEB_BUILD_ARCH=$DEB_ARCH"
echo "DEB_HOST_ARCH=$DEB_ARCH"
